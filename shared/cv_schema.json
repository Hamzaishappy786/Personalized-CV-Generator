{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CV Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "headline": { "type": "string" },
    "summary": { "type": "string" },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "linkedin": { "type": "string" },
        "portfolio": { "type": "string" }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "degree": { "type": "string" },
          "institution": { "type": "string" },
          "year": { "type": "string" }
        },
        "required": ["degree"]
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "company": { "type": "string" },
          "duration": { "type": "string" },
          "location": { "type": "string" },
          "bullets": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills_used": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["title", "company"]
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "tech": {
            "type": "array",
            "items": { "type": "string" }
          },
          "link": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string" }
    },
    "awards": {
      "type": "array",
      "items": { "type": "string" }
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
